# Create a bot via @BotFather and put its token here. Never commit .env.
TELEGRAM_BOT_TOKEN=

# Comma-separated allow-listed group IDs. This is required in every environment.
# A private supergroup ID normally begins with -100.
ALLOWED_CHAT_IDS=

# SQLite path. The parent directory must exist.
DATABASE_PATH=./data/index.db

# Analyze only Telegram photo messages with local Ollama vision. Start in shadow
# mode to measure recognition without writing new records; set to index only after
# validating representative photos.
PHOTO_RECOGNITION_MODE=shadow
# detector-crop = local detector → enlarged crop → Ollama (recommended accuracy-first default).
# detector-fast-ocr = local detector → FastPlateOCR reader (experimental flow 3; benchmark in shadow mode first).
# full-image is a legacy diagnostic fallback; do not use it for a new deployment.
PHOTO_RECOGNITION_STRATEGY=detector-crop
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl:7b
# Used only by detector-fast-ocr; this is a local ~5 MB ONNX reader, not an Ollama model.
FAST_PLATE_OCR_MODEL=cct-s-v2-global-model
# This acknowledgement is additionally required before Flow 3 may write records after its shadow benchmark.
# FAST_PLATE_OCR_ALLOW_INDEX=true
OLLAMA_TIMEOUT_MS=60000
# Required by detector-crop and detector-fast-ocr. All are local files and source images remain in memory.
PLATE_DETECTOR_PYTHON=./.vision-venv/bin/python
PLATE_DETECTOR_SCRIPT=./scripts/detect_plate_crops.py
PLATE_DETECTOR_MODEL=./models/license-plate-detector.pt
